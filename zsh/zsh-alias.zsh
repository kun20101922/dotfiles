KEYTIMEOUT=1

alias hyprland="start-hyprland"

alias g="git"

alias neovim="NVIM_APPNAME=neovim nvim"

alias dwl="~/dwl_start"

alias kbs1="brightnessctl --device='input19::scrolllock' set 1"
alias kbs0="brightnessctl --device='input19::scrolllock' set 0"

alias ls="ls --color=auto"
alias ll="ls -la"
alias l="ls -l"

alias ..="cd .."
alias ...="cd ..."

alias y="yazi"

alias vim="vim"
alias vi='vi'

alias zshreload="source ~/.zshrc"
alias tmuxreload="tmux source  ~/.config/tmux/tmux.conf"

alias shutdown="shutdown now"

alias nvim-conf="cd ~/.config/nvim; nvim init.lua"





